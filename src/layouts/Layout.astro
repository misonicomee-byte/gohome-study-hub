---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "ごうホームクリニックが運営する、訪問診療を学ぶ医療職向けの情報資料室です。WEB勉強会動画・関連資料を集約しています。" } = Astro.props;
const siteName = "ごうホームクリニック 訪問診療情報資料室";
const fullTitle = title === siteName ? title : `${title}｜${siteName}`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen bg-brand-50 text-brand-900 font-sans antialiased">
    <header class="sticky top-0 z-50 backdrop-blur-md bg-white/80 border-b border-brand-100">
      <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <img
            src="/logo.png"
            alt="ごうホームクリニック"
            class="h-10 w-auto"
            width="80"
            height="60"
          />
          <div>
            <div class="text-sm font-bold tracking-wide text-brand-700 leading-tight">ごうホームクリニック</div>
            <div class="text-xs text-brand-500 leading-tight">訪問診療情報資料室</div>
          </div>
        </a>
        <div class="hidden md:flex items-center gap-5 text-sm font-medium">
          <a href="/" class="nav-link text-brand-700 hover:text-brand-900">ホーム</a>
          <a href="/instagram/" class="nav-link text-brand-700 hover:text-brand-900">Instagram</a>
          <a href="/#lectures" class="nav-link text-brand-700 hover:text-brand-900">勉強会</a>
          <a href="https://gohome-clinic.com" class="nav-link text-brand-700 hover:text-brand-900" target="_blank" rel="noopener">本院サイト</a>
          <a href="https://gohome-clinic.com/recruit/" class="nav-link text-brand-700 hover:text-brand-900" target="_blank" rel="noopener">採用情報</a>
          <a href="https://www.instagram.com/gohomeclinic" class="nav-link text-pink-600 hover:text-pink-700 inline-flex items-center gap-1" target="_blank" rel="noopener" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
        <a
          href="/line"
          class="hidden md:inline-flex items-center gap-2 bg-line text-white px-4 py-2 rounded-full text-sm font-semibold shadow-sm hover:shadow-md transition-shadow"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.508.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
          公式LINE登録
        </a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-24 border-t border-brand-100 bg-white/60">
      <div class="max-w-6xl mx-auto px-6 py-12 grid md:grid-cols-3 gap-8 text-sm text-brand-700">
        <div>
          <div class="font-bold text-brand-900 mb-2">ごうホームクリニック</div>
          <p class="leading-relaxed">
            名古屋市天白区を拠点に、名古屋市16区および日進市・東郷町・豊明市・刈谷市・知立市で訪問診療を行う在宅療養支援診療所です。
          </p>
        </div>
        <div>
          <div class="font-bold text-brand-900 mb-2">関連サイト</div>
          <ul class="space-y-1.5">
            <li><a href="https://gohome-clinic.com" target="_blank" rel="noopener" class="hover:text-brand-500">本院サイト</a></li>
            <li><a href="https://gohome-clinic.com/blog/" target="_blank" rel="noopener" class="hover:text-brand-500">ブログ一覧</a></li>
            <li><a href="https://gohome-clinic.com/recruit/" target="_blank" rel="noopener" class="hover:text-brand-500">採用情報（リクルート）</a></li>
            <li><a href="https://www.instagram.com/gohomeclinic" target="_blank" rel="noopener" class="hover:text-brand-500">Instagram公式</a></li>
            <li><a href="/line" class="hover:text-brand-500">公式LINEのご案内</a></li>
          </ul>
        </div>
        <div>
          <div class="font-bold text-brand-900 mb-2">資料室について</div>
          <p class="leading-relaxed">
            毎月開催のWEB勉強会を中心に、訪問診療を学びたい医療職の方向けの資料を集約しています。舞台裏トークも含む、現場のリアルを共有します。
          </p>
        </div>
      </div>
      <div class="border-t border-brand-100 py-6 text-center text-xs text-brand-500">
        © ごうホームクリニック 訪問診療情報資料室
      </div>
    </footer>
  </body>
</html>
