---
import { type BlogPost, formatRelativeDate } from "../data/portal";

interface Props {
  post: BlogPost;
  rank?: number; // 人気ランキング用
}
const { post, rank } = Astro.props;
---

<article class="lecture-card group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl border border-brand-100 relative">
  {rank !== undefined && (
    <div class="absolute top-3 left-3 z-10 w-9 h-9 rounded-full bg-amber-500 text-white grid place-items-center font-bold shadow-lg">
      {rank}
    </div>
  )}
  <a href={post.link} target="_blank" rel="noopener" class="block">
    {post.thumbnail ? (
      <div class="relative aspect-video overflow-hidden bg-brand-100">
        <img
          src={post.thumbnail}
          alt={post.title}
          loading="lazy"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
      </div>
    ) : (
      <div class="aspect-video bg-gradient-to-br from-brand-100 to-brand-200 grid place-items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5h-1A2.5 2.5 0 0014 9.5V11" />
        </svg>
      </div>
    )}
    <div class="p-5">
      <div class="flex items-center gap-2 text-xs text-brand-500 mb-2">
        <span>{post.date ? formatRelativeDate(post.date) : "公開日不明"}</span>
        <span>•</span>
        <span>ブログ</span>
        {post.pageViews !== undefined && post.pageViews > 0 && (
          <>
            <span>•</span>
            <span class="text-amber-600 font-semibold">👁 {post.pageViews.toLocaleString()} views</span>
          </>
        )}
      </div>
      <h3 class="font-bold text-brand-900 leading-tight mb-2 group-hover:text-brand-600 transition-colors line-clamp-2">
        {post.title}
      </h3>
      {post.excerpt && (
        <p class="text-sm text-brand-700/80 leading-relaxed line-clamp-2">
          {post.excerpt}
        </p>
      )}
    </div>
  </a>
</article>
