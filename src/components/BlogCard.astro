---
import { type BlogPost, formatRelativeDate } from "../data/portal";

interface Props {
  post: BlogPost;
  rank?: number; // 人気ランキング用
}
const { post, rank } = Astro.props;

// テーマ別のアクセントカラー（タイトル内容から推測）
function accentForTitle(t: string): { from: string; to: string; ring: string } {
  if (t.match(/嚥下|食|栄養/)) return { from: "from-orange-400", to: "to-pink-500", ring: "ring-orange-100" };
  if (t.match(/認知症|看取り|終末|ACP/)) return { from: "from-purple-400", to: "to-fuchsia-500", ring: "ring-purple-100" };
  if (t.match(/褥瘡|皮膚|脱水|点滴/)) return { from: "from-rose-400", to: "to-red-500", ring: "ring-rose-100" };
  if (t.match(/連携|多職種|看護|薬剤/)) return { from: "from-sky-400", to: "to-blue-500", ring: "ring-sky-100" };
  if (t.match(/改定|算定|報酬|加算/)) return { from: "from-amber-400", to: "to-yellow-500", ring: "ring-amber-100" };
  if (t.match(/勉強会|YouTube|動画/)) return { from: "from-emerald-400", to: "to-teal-500", ring: "ring-emerald-100" };
  return { from: "from-brand-400", to: "to-brand-600", ring: "ring-brand-100" };
}
const accent = accentForTitle(post.title);
---

<article
  class="lecture-card group relative bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl border border-brand-100 flex flex-col"
>
  {/* 上部のグラデーション・ストライプ */}
  <div class={`h-1.5 bg-gradient-to-r ${accent.from} ${accent.to}`}></div>

  {rank !== undefined && (
    <div class="absolute top-4 right-4 z-10 w-10 h-10 rounded-full bg-gradient-to-br from-amber-400 to-amber-600 text-white grid place-items-center font-bold shadow-lg ring-4 ring-white">
      {rank}
    </div>
  )}

  <a href={post.link} target="_blank" rel="noopener" class="flex-1 flex flex-col p-5">
    <div class="flex items-center gap-2 text-xs text-brand-500 mb-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5h-1A2.5 2.5 0 0014 9.5V11" />
      </svg>
      <span class="font-semibold">本院ブログ</span>
      {post.date && (
        <>
          <span class="text-brand-300">•</span>
          <span>{formatRelativeDate(post.date)}</span>
        </>
      )}
    </div>

    <h3 class="text-base font-bold text-brand-900 leading-snug mb-3 group-hover:text-brand-600 transition-colors line-clamp-3">
      {post.title}
    </h3>

    <div class="flex-1"></div>

    {post.pageViews !== undefined && post.pageViews > 0 && (
      <div class="flex items-center justify-between pt-3 border-t border-brand-100">
        <div class="flex items-center gap-3 text-xs text-brand-600">
          <span class="inline-flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            <span class="font-semibold text-brand-900">{post.pageViews.toLocaleString()}</span>
            <span>views</span>
          </span>
          {post.totalUsers !== undefined && post.totalUsers > 0 && (
            <span class="inline-flex items-center gap-1 text-brand-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              {post.totalUsers.toLocaleString()}
            </span>
          )}
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-400 group-hover:text-brand-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </div>
    )}
  </a>
</article>
