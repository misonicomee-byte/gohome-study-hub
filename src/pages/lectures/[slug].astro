---
import Layout from "../../layouts/Layout.astro";
import LectureCard from "../../components/LectureCard.astro";
import { LECTURES, formatDateLabel, type Lecture } from "../../data/lectures";

export function getStaticPaths() {
  return LECTURES.map((lecture) => ({
    params: { slug: lecture.slug },
    props: { lecture },
  }));
}

interface Props {
  lecture: Lecture;
}
const { lecture } = Astro.props;

// 関連動画：同じテーマを持つ他の動画
const related = LECTURES
  .filter(
    (l) => l.slug !== lecture.slug && l.themes.some((t) => lecture.themes.includes(t))
  )
  .slice(0, 3);
---

<Layout title={lecture.title} description={lecture.description}>
  <article class="max-w-5xl mx-auto px-6 py-8 md:py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-brand-600 mb-6">
      <a href="/" class="hover:text-brand-800">ホーム</a>
      <span class="mx-2 opacity-50">/</span>
      <a href="/#lectures" class="hover:text-brand-800">資料一覧</a>
      <span class="mx-2 opacity-50">/</span>
      <span class="text-brand-800">{formatDateLabel(lecture.date)}</span>
    </nav>

    <!-- Title -->
    <header class="mb-8">
      <span class="inline-block text-xs font-bold tracking-wider text-amber-600 mb-3">
        {formatDateLabel(lecture.date)} 開催
      </span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-brand-900 leading-tight mb-4">
        {lecture.title}
      </h1>
      <div class="flex flex-wrap gap-1.5">
        {lecture.themes.map((t) => (
          <span class="text-sm px-3 py-1 rounded-full bg-brand-100 text-brand-700 border border-brand-200">
            #{t}
          </span>
        ))}
      </div>
    </header>

    <!-- Video -->
    <div class="aspect-video rounded-2xl overflow-hidden shadow-2xl mb-8 bg-black">
      <iframe
        src={`https://www.youtube.com/embed/${lecture.youtubeId}?rel=0`}
        title={lecture.title}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
        class="w-full h-full"
      ></iframe>
    </div>

    <!-- Description -->
    <div class="bg-white rounded-2xl p-6 md:p-8 shadow-sm border border-brand-100 mb-8">
      <h2 class="text-xl font-bold text-brand-900 mb-3">この回について</h2>
      <p class="text-brand-700 leading-relaxed">{lecture.description}</p>
    </div>

    <!-- Related Blog -->
    {lecture.blogUrl && (
      <div class="bg-gradient-to-br from-brand-50 to-white rounded-2xl p-6 md:p-8 border border-brand-100 mb-8">
        <h2 class="text-lg font-bold text-brand-900 mb-3 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5h-1A2.5 2.5 0 0014 9.5V11" />
          </svg>
          関連ブログ記事
        </h2>
        <a
          href={lecture.blogUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-brand-600 hover:text-brand-700 font-semibold"
        >
          ごうホームクリニックブログで読む
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    )}

    <!-- LINE CTA -->
    <div class="bg-gradient-to-br from-[--color-line] to-emerald-600 rounded-2xl p-6 md:p-8 text-white mb-12 shadow-lg">
      <div class="md:flex items-center justify-between gap-6">
        <div class="mb-4 md:mb-0">
          <h3 class="text-lg md:text-xl font-bold mb-2">次回WEB勉強会のご案内をLINEで配信中</h3>
          <p class="text-white/90 text-sm leading-relaxed">
            毎月のテーマ告知、新規動画追加もLINEから。
          </p>
        </div>
        <a href="/line" class="inline-flex items-center gap-2 bg-white text-emerald-700 px-5 py-2.5 rounded-full font-bold shadow-md hover:shadow-lg hover:scale-105 transition-all whitespace-nowrap">
          LINEを見る
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7-7 7M5 12h16" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Related Lectures -->
    {related.length > 0 && (
      <section>
        <h2 class="text-2xl font-bold text-brand-900 mb-6">関連する資料</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {related.map((l) => <LectureCard lecture={l} />)}
        </div>
      </section>
    )}
  </article>
</Layout>
