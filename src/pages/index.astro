---
import Layout from "../layouts/Layout.astro";
import LectureCard from "../components/LectureCard.astro";
import { getLecturesSortedByDate, getAllThemes, LECTURES, formatDateLabel } from "../data/lectures";

const lectures = getLecturesSortedByDate();
const themes = getAllThemes();
const latest = lectures[0];
---

<Layout title="ごうホームクリニック 訪問診療情報資料室">
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-50 via-white to-brand-100">
    <div class="absolute inset-0 opacity-30 pointer-events-none">
      <div class="absolute -top-32 -right-32 w-96 h-96 bg-brand-200 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-amber-200 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-6 py-16 md:py-24">
      <div class="max-w-3xl">
        <span class="inline-block text-xs font-bold tracking-widest text-brand-600 mb-4 uppercase">
          For Healthcare Professionals
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-900 leading-tight mb-6">
          訪問診療を、<br />
          <span class="text-brand-600">本気で語る</span>場所。
        </h1>
        <p class="text-lg md:text-xl text-brand-700 leading-relaxed mb-8">
          ごうホームクリニックが運営する、訪問診療の情報資料室。<br />
          毎月のWEB勉強会動画を中心に、舞台裏トークも含む現場のリアルを医療職同士で共有しています。
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="#lectures" class="inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white px-6 py-3 rounded-full font-semibold shadow-md hover:shadow-lg transition-all">
            資料を見る
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
          <a href="/line" class="inline-flex items-center gap-2 bg-white hover:bg-brand-50 text-brand-700 border border-brand-200 px-6 py-3 rounded-full font-semibold transition-all">
            公式LINEに登録する
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Featured -->
  {latest && (
    <section class="max-w-6xl mx-auto px-6 -mt-8 relative z-10">
      <div class="bg-white rounded-3xl shadow-xl border border-brand-100 overflow-hidden">
        <div class="grid md:grid-cols-2 gap-0">
          <a href={`/lectures/${latest.slug}/`} class="relative aspect-video md:aspect-auto bg-brand-100 group block">
            <img
              src={`https://i.ytimg.com/vi/${latest.youtubeId}/maxresdefault.jpg`}
              onerror={`this.src='https://i.ytimg.com/vi/${latest.youtubeId}/hqdefault.jpg'`}
              alt={latest.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute inset-0 bg-gradient-to-tr from-black/30 to-transparent"></div>
            <div class="absolute top-4 left-4 bg-amber-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-md">
              ★ 最新
            </div>
            <div class="absolute inset-0 grid place-items-center">
              <div class="w-16 h-16 rounded-full bg-white/95 backdrop-blur grid place-items-center shadow-2xl group-hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-brand-700 translate-x-0.5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M8 5v14l11-7L8 5z" />
                </svg>
              </div>
            </div>
          </a>
          <div class="p-6 md:p-10 flex flex-col justify-center">
            <span class="text-xs font-bold tracking-wider text-amber-600 mb-2">{formatDateLabel(latest.date)}</span>
            <h2 class="text-2xl md:text-3xl font-bold text-brand-900 leading-tight mb-4">{latest.title}</h2>
            <p class="text-brand-700 leading-relaxed mb-6">{latest.description}</p>
            <div class="flex flex-wrap gap-1.5 mb-6">
              {latest.themes.map((t) => (
                <span class="text-xs px-2.5 py-1 rounded-full bg-brand-50 text-brand-600 border border-brand-100">#{t}</span>
              ))}
            </div>
            <a href={`/lectures/${latest.slug}/`} class="inline-flex items-center gap-2 text-brand-600 hover:text-brand-700 font-semibold">
              この動画を見る
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7-7 7M5 12h16" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Themes Filter -->
  <section id="themes" class="max-w-6xl mx-auto px-6 py-16">
    <div class="mb-8">
      <h2 class="text-2xl md:text-3xl font-bold text-brand-900 mb-2">テーマで探す</h2>
      <p class="text-brand-700">気になるテーマを選ぶと、関連する資料だけが表示されます。</p>
    </div>
    <div class="flex flex-wrap gap-2" id="theme-buttons">
      <button type="button" data-theme-filter="all" class="px-4 py-2 rounded-full text-sm font-medium bg-brand-600 text-white shadow-sm transition-colors">
        すべて <span class="ml-1 opacity-75">({LECTURES.length})</span>
      </button>
      {themes.map((t) => (
        <button type="button" data-theme-filter={t.name} class="px-4 py-2 rounded-full text-sm font-medium bg-white text-brand-700 border border-brand-200 hover:bg-brand-50 transition-colors">
          {t.name} <span class="ml-1 opacity-60">({t.count})</span>
        </button>
      ))}
    </div>
  </section>

  <!-- Lecture Grid -->
  <section id="lectures" class="max-w-6xl mx-auto px-6 pb-24">
    <div class="mb-8 flex items-end justify-between">
      <div>
        <h2 class="text-2xl md:text-3xl font-bold text-brand-900 mb-2">資料一覧</h2>
        <p class="text-brand-700">
          <span id="visible-count">{LECTURES.length}</span> / {LECTURES.length} 件
        </p>
      </div>
    </div>
    <div id="lecture-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {lectures.map((l) => <LectureCard lecture={l} />)}
    </div>
  </section>

  <!-- LINE CTA -->
  <section class="max-w-6xl mx-auto px-6 pb-24">
    <div class="bg-gradient-to-br from-[--color-line] to-emerald-600 rounded-3xl p-8 md:p-12 text-white shadow-xl">
      <div class="md:flex items-center justify-between gap-8">
        <div class="mb-6 md:mb-0">
          <h2 class="text-2xl md:text-3xl font-bold mb-3">次回WEB勉強会のご案内を、LINEで配信中</h2>
          <p class="text-white/90 leading-relaxed">
            次回のテーマ・開催日時を、公式LINEから配信しています。<br />
            新着動画もLINEでお知らせします。
          </p>
        </div>
        <a href="/line" class="inline-flex items-center gap-2 bg-white text-emerald-700 px-6 py-3 rounded-full font-bold shadow-md hover:shadow-lg hover:scale-105 transition-all whitespace-nowrap">
          公式LINEを見る
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7-7 7M5 12h16" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>("[data-theme-filter]");
    const cards = document.querySelectorAll<HTMLElement>("[data-lecture]");
    const counter = document.getElementById("visible-count");

    function applyFilter(theme: string) {
      let visible = 0;
      cards.forEach((card) => {
        const themes = (card.dataset.themes ?? "").split(",");
        const show = theme === "all" || themes.includes(theme);
        card.toggleAttribute("hidden", !show);
        if (show) visible++;
      });
      if (counter) counter.textContent = visible.toString();
      buttons.forEach((b) => {
        const isActive = b.dataset.themeFilter === theme;
        if (isActive) {
          b.classList.add("bg-brand-600", "text-white", "shadow-sm");
          b.classList.remove("bg-white", "text-brand-700", "border", "border-brand-200");
        } else {
          b.classList.remove("bg-brand-600", "text-white", "shadow-sm");
          b.classList.add("bg-white", "text-brand-700", "border", "border-brand-200");
        }
      });
    }
    buttons.forEach((b) => b.addEventListener("click", () => applyFilter(b.dataset.themeFilter ?? "all")));
  </script>
</Layout>
